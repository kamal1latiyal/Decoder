# .env.example — copy to .env and fill in, OR just `export` them in your shell.
#
# These are needed ONLY for the Pipecat voice-agent demo
# (pipecat_integration/demo.py). The TTS server (server/app.py), the smoke
# tests, the benchmarks, and bootstrap.sh do NOT need any of these.
#
# .env files are gitignored.

# ── REQUIRED for the demo ────────────────────────────────────────────────
# Deepgram (STT). Sign up: https://console.deepgram.com  ($200 free credit)
DEEPGRAM_API_KEY=

# Anthropic (LLM — Claude Opus 4.7). Sign up: https://console.anthropic.com
ANTHROPIC_API_KEY=


# ── OPTIONAL voice-clone overrides ───────────────────────────────────────
# REF_AUDIO defaults to refs/voice.wav (auto-downloaded by bootstrap if missing).
# REF_TEXT  is optional. If set, qwen_tts uses ICL voice-clone mode (slightly
#           higher fidelity). If unset, x-vector-only mode is used (no
#           transcript needed; works fine for arbitrary voices).
# REF_AUDIO=/workspace/Decoder/refs/voice.wav
# REF_TEXT="exact transcript of voice.wav"


# ── OPTIONAL server / demo overrides ─────────────────────────────────────
# Where the Pipecat demo finds the TTS server (default: ws://localhost:8765).
# TTS_SERVER_URL=ws://localhost:8765
